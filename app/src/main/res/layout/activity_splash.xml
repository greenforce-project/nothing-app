<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/splash_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nothing_background">

    <LinearLayout
        android:id="@+id/splash_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <View
            android:id="@+id/splash_dot"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/splash_dot" />

        <TextView
            android:id="@+id/splash_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:fontFamily="sans-serif"
            android:includeFontPadding="false"
            android:letterSpacing="0.02"
            android:text="@string/splash_title"
            android:textColor="@color/nothing_foreground"
            android:textSize="44sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/splash_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:text="@string/splash_subtitle"
            android:textColor="@color/nothing_muted"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/splash_credit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:letterSpacing="0.02"
            android:text="@string/splash_credit"
            android:textColor="@color/nothing_muted"
            android:textSize="12sp" />

    </LinearLayout>

</FrameLayout>
